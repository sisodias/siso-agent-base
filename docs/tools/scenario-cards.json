      "workflowStages": [
        "recon",
        "debugging",
        "planning"
      ],
      "useWhen": [
        "Need to find code/docs by text, phrase, command, error, config key, or filename.",
        "Do not know the exact file path yet."
      ],
      "avoidWhen": [
        "Exact paths are already known; use readMany.",
        "Need a task-level evidence bundle; use contextPack or briefRepo."
      ],
      "replacesShellPatterns": [
        "find | grep",
        "rg with huge raw dumps"
      ],
      "requiredInputs": [
        "query"
      ],
      "expectedOutputs": [
        "path",
        "line",
        "preview"
      ],
      "failureModes": [
