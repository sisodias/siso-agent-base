        "low-signal matches",
        "generated/vendor directory noise"
      ],
      "relatedCapabilities": [
        "agent-tooling-roadmap"
      ],
      "relatedContracts": [],
      "relatedBenchmarkSuites": [
        "code-intel-navigation",
        "tool-selection-correctness"
      ],
      "validationCommands": [
        "npm run smoke:agent-tooling",
        "npm run smoke:tool-scenario-cards"
      ]
    },
