#!/usr/bin/env bash
set -euo pipefail

INSTALL_DIR="${SISO_AGENT_BASE_DIR:-$HOME/.siso-agent-base}"
SOURCE_DIR="${SISO_AGENT_BASE_SOURCE_DIR:-$HOME/SISO_Workspace/SISO_Agent_Base}"

if [[ -d "$INSTALL_DIR/.git" ]]; then
  git -C "$INSTALL_DIR" pull --ff-only
  exec "$INSTALL_DIR/scripts/install-local.sh" "$@"
fi

if [[ -d "$SOURCE_DIR/.git" && -x "$SOURCE_DIR/scripts/install-local.sh" ]]; then
  git -C "$SOURCE_DIR" pull --ff-only
  exec "$SOURCE_DIR/scripts/install-local.sh" "$@"
fi

echo "siso update: install dir has no .git at $INSTALL_DIR and canonical source checkout is missing at $SOURCE_DIR; rerun install.sh or set SISO_AGENT_BASE_SOURCE_DIR" >&2
exit 1
